rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Public access for a specific default image
    match /public/{fileName} {
      allow read: if true;
    }

    // Secure user profile photos
    match /profilePhotos/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Secure user-specific uploads
    match /user_uploads/{userId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Mechanic onboarding documents
    match /mechanic-documents/{mechanicId}/{documentType}/{fileName} {
      // Allow mechanic to upload their own documents
      allow write: if request.auth != null && request.auth.uid == mechanicId;
      // Allow mechanic and admins to read their documents
      allow read: if request.auth != null && 
                     (request.auth.uid == mechanicId || 
                      get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Block all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
